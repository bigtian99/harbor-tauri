{
  "name": "jarporter",
  "private": true,
  "version": "0.2.35",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:arm64": "tauri build --target aarch64-apple-darwin",
    "tauri:build:x64": "tauri build --target x86_64-apple-darwin",
    "tauri:build:universal": "tauri build --target universal-apple-darwin",
    "tauri:build:ops": "node scripts/tauri-build-ops.mjs aarch64-apple-darwin",
    "tauri:build:ops:win64": "node scripts/tauri-build-ops.mjs x86_64-pc-windows-msvc",
    "tauri:build:all": "pnpm tauri:build:arm64 && pnpm tauri:build:x64",
    "version:set": "node scripts/set-version.mjs",
    "version:patch": "node scripts/set-version.mjs patch",
    "version:minor": "node scripts/set-version.mjs minor",
    "version:major": "node scripts/set-version.mjs major",
    "release": "node scripts/release.mjs",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {
    "@mantine/core": "^9.4.0",
    "@mantine/hooks": "^9.4.0",
    "@mantine/notifications": "^9.4.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
