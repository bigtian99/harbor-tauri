{
  "name": "jarporter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:arm64": "tauri build --target aarch64-apple-darwin",
    "tauri:build:x64": "tauri build --target x86_64-apple-darwin",
    "tauri:build:universal": "tauri build --target universal-apple-darwin",
    "tauri:build:all": "pnpm tauri:build:arm64 && pnpm tauri:build:x64",
    "release": "git tag -a v$npm_package_version -m 'v$npm_package_version' && git push origin v$npm_package_version"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
